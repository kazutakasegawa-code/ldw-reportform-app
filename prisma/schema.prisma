generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Submission {
  id                         String           @id @default(cuid())
  resultToken                String           @unique
  companyName                String
  industry                   String
  employeeCount              String
  officeCount                String
  contactName                String
  contactRole                String
  email                      String
  phone                      String
  targetLayer                String
  targetCount                String
  desiredTiming              String
  pastTraining               String
  mainIssues                 String
  expectedPeriod             String
  budgetRange                String
  notes                      String?
  hearingMostImportantIssue  String
  hearingTargetLayer         String
  hearingIdealState          String
  hearingFollowSystem        String
  hearingQuestion            String?
  consentPrivacy             Boolean
  consentAi                  Boolean
  status                     String           @default("5分診断完了")
  meetingDate                DateTime?
  reportDate                 DateTime?
  meetingMemo                String?
  priorityIssue              String?
  recommendedPlan            String?
  reportComment              String?
  resultViewedAt             DateTime?
  ctaClickedAt               DateTime?
  meetingRequestedAt         DateTime?
  preferredMeetingDates      String?
  meetingRequestMemo         String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  checkAnswers               CheckAnswer[]
  analysisResult             AnalysisResult?
}

model CheckAnswer {
  id           String     @id @default(cuid())
  submissionId String
  questionNo   Int
  domain       String
  question     String
  viewpoint    String
  score        Int
  comment      String?
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model AnalysisResult {
  id                 String     @id @default(cuid())
  submissionId       String     @unique
  overallFinding     String?
  strengths          String?
  topIssues          String?
  visibleProblems    String?
  causeHypotheses    String?
  actionsToIncrease  String?
  actionsToDecrease  String?
  thingiFit          String?
  notebookFit        String?
  coachingFit        String?
  recommendedProgram String?
  kpis               String?
  managementSupport  String?
  domainComments     String?
  additionalQuestions String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  submission         Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}
